# Supabase (Settings → API): required for auth and data
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Backend API: required for course bootstrap, grades, study, extension proxy
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: must match backend INTERNAL_HEALTH_TOKEN; enables the “OpenAI” LLM badge on the dashboard
# NEXT_PUBLIC_HEALTH_TOKEN=your-internal-health-token

# Dev login (fixed email/password) is on by default in next dev. Set to false to force real Supabase only:
# NEXT_PUBLIC_DEV_AUTH_BYPASS=false
# Optional: must match backend DEV_BEARER_TOKEN when DEV_AUTH_BYPASS=true there
# NEXT_PUBLIC_DEV_BEARER_TOKEN=courseintel-local-dev-bearer
