# ── LLM Providers ────────────────────────────────────────────────────────────
# Primary: Anthropic Claude (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Fallback: Google Gemini (optional but strongly recommended)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza-your-key-here

LLM_FALLBACK_ENABLED=true

# ── Web Search ────────────────────────────────────────────────────────────────
# Tavily — purpose-built search API for LLM apps
# Get from: https://app.tavily.com
TAVILY_API_KEY=tvly-your-key-here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...your-service-role-key-here

# JWT secret for validating Supabase-issued tokens server-side
# Find in: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=http://localhost:3000

# ── Security ─────────────────────────────────────────────────────────────────
# Random token required to call /health/llm (generate with: openssl rand -hex 32)
INTERNAL_HEALTH_TOKEN=generate-a-long-random-string-here

# ── Limits ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760       # 10 MB
RATE_LIMIT_PER_MINUTE=30
