# ── LLM (required for agent features) ───────────────────────────────────────
# Set ONE of the following. OpenAI takes precedence if both are present.
#
# Option A — OpenAI (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here
#
# Option B — Groq (FREE tier, 14 400 req/day): https://console.groq.com/keys
# Uses llama-3.3-70b-versatile (OPUS/SONNET) and llama-3.1-8b-instant (HAIKU).
# Comment out OPENAI_API_KEY above and uncomment below to use Groq:
# GROQ_API_KEY=gsk_your-groq-key-here

# ── Web Search ──────────────────────────────────────────────────────────────
# Get from: https://app.tavily.com
TAVILY_API_KEY=tvly-your-key-here

# ── Supabase ─────────────────────────────────────────────────────────────────
# All three from: Supabase Dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Security ────────────────────────────────────────────────────────────────
# Optional: same value as frontend NEXT_PUBLIC_HEALTH_TOKEN for dashboard LLM status badge
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_HEALTH_TOKEN=generate-a-long-random-string

# Local demo only: accept Bearer DEV_BEARER_TOKEN instead of Supabase JWT (must match frontend)
# DEV_AUTH_BYPASS=true
# DEV_BEARER_TOKEN=courseintel-local-dev-bearer

# Optional: Clerk session JWT verification (RS256). Clerk Dashboard → API Keys → show JWT issuer;
# JWKS URL is typically: https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# ── Limits ──────────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760
RATE_LIMIT_PER_MINUTE=30
